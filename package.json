{
  "name": "agentforge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AgentForge - Multi-Agent Management System based on OpenClaw",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "server": "npx tsx server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.ts,.tsx",
    "lint:fix": "eslint src --ext .vue,.ts,.tsx --fix"
  },
  "dependencies": {
    "@pureadmin/components": "^1.1.0",
    "@pureadmin/theme": "^3.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "d3-flextree": "^2.1.2",
    "d3-org-chart": "^3.1.1",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.5",
    "express": "^5.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
